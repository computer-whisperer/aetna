#!/usr/bin/env bash
# render — one command to produce the full agent feedback bundle for an
# example.
#
# Usage:  ./tools/render <example-name> [-p <package>]
#
# Defaults: package=aetna-core.
#
# Runs the cargo example (which writes the bundle artifacts), converts
# the SVG to PNG, then prints the path of every artifact.

set -uo pipefail

example="${1:-}"
shift || true
pkg="aetna-core"

while [ $# -gt 0 ]; do
    case "$1" in
        -p|--package) pkg="$2"; shift 2 ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

cd "$(dirname "$0")/.."

if [ -z "$example" ]; then
    echo "usage: $0 <example-name> [-p <package>]" >&2
    echo >&2
    echo "available examples in $pkg:" >&2
    if [ -d "crates/$pkg" ]; then
        find "crates/$pkg/examples" -maxdepth 1 -name '*.rs' -printf '  %f\n' 2>/dev/null \
        | sed 's/\.rs$//' >&2
    fi
    exit 2
fi

if [ -d "crates/$pkg" ]; then
    pkg_dir="crates/$pkg"
else
    echo "unknown package directory for '$pkg' (expected crates/$pkg)" >&2
    exit 2
fi

cargo run -q -p "$pkg" --example "$example" || exit $?

# Produce PNGs for the just-rendered SVG.
./tools/svg_to_png.sh >/dev/null 2>&1 || true

out_dir="$pkg_dir/out"
echo
echo "artifacts:"
for ext in svg png tree.txt lint.txt draw_ops.txt shader_manifest.txt; do
    f="$out_dir/$example.$ext"
    [ -f "$f" ] && echo "  $f"
done

exit 0
