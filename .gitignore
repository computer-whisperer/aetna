target/

# Rendered PNG fixtures — regenerated from SVG by tools/svg_to_png.sh
# (and from the wgpu render bins in aetna-demo/out/).
attempts/*/out/*.png

# Bundle artifacts under crates/*/out/ regenerate on every example run
# (svg, tree.txt, draw_ops.txt, lint.txt, shader_manifest.txt, png).
# attempts/*/out/ stays tracked as a historical snapshot.
crates/*/out/*

# wasm-pack output for aetna-web — regenerated by tools/build_web.sh
# (default `wasm-pack` target dir, ~20MB in dev mode, ~1MB in release).
crates/aetna-web/pkg/
