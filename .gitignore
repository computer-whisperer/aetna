target/

# Per-repo agent / IDE state (Claude Code, Codex, generic .agents
# scratch). Always local — nothing here is part of the project's
# source.
.claude/
.codex/
.agents/

# Bundle artifacts under crates/*/out/ regenerate on every example run
# (svg, tree.txt, draw_ops.txt, lint.txt, shader_manifest.txt, png).
crates/*/out/*

# Render outputs from tools/src/bin/ (showcase pngs, msdf atlases,
# text-quality comparisons, etc.) — regenerated on demand.
tools/out/

# wasm-pack output for web demos — regenerated by tools/build_web.sh
# (default `wasm-pack` target dir, ~20MB in dev mode, ~1MB in release).
crates/aetna-web/pkg/
crates/aetna-web-showcase/pkg/

# Xcode local state for the iOS showcase package.
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/
ios/DerivedData/

# Reference web harnesses — source + lockfiles are tracked, generated
# dependencies/builds/screenshots are local artifacts.
references/*/node_modules/
references/*/dist/
references/*/out/
