{
  "name": "aetna-shadcn-calibration",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "screenshot": "npm run screenshot:calibration && npm run screenshot:dashboard",
    "screenshot:calibration": "chromium --headless --disable-gpu --no-sandbox --screenshot=out/shadcn-calibration.png --window-size=1180,780 http://127.0.0.1:5173",
    "screenshot:dashboard": "chromium --headless --disable-gpu --no-sandbox --screenshot=out/shadcn-dashboard-01.png --window-size=1180,780 \"http://127.0.0.1:5173?view=dashboard-01\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
